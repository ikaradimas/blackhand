{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BlackHand",
  "version": "0.2.4",
  "identifier": "app.blackhand.client",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "BlackHand",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "theme": "Dark",
        "titleBarStyle": "Visible",
        "backgroundColor": "#07070C"
      },
      {
        "label": "tray-popup",
        "url": "/tray-popup",
        "title": "BlackHand status",
        "width": 320,
        "height": 260,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "focus": false,
        "shadow": true,
        "backgroundColor": "#07070C"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["magnet"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["torrent"],
        "name": "BitTorrent metainfo file",
        "description": "BitTorrent file",
        "role": "Editor",
        "mimeType": "application/x-bittorrent"
      }
    ]
  }
}
