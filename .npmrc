supported-architectures.os[]=darwin
supported-architectures.os[]=win32
supported-architectures.os[]=linux
supported-architectures.cpu[]=x64
supported-architectures.cpu[]=arm64

# Use a flat node_modules instead of pnpm's symlinked virtual store.
# esbuild + several other native-binary postinstalls are unreliable on Windows
# with the default symlinked layout.
node-linker=hoisted
